<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.dingtalk.mapper.BizTargetYearMapper">
    <resultMap id="BaseResult" type="com.ruoyi.dingtalk.domain.biz.BizTargetYear"><id property="id" column="id"/><result property="year" column="year"/><result property="companySubjectId" column="company_subject_id"/><result property="profitUnitId" column="profit_unit_id"/><result property="companyName" column="company_name"/><result property="subjectName" column="subject_name"/><result property="profitUnitName" column="profit_unit_name"/><result property="platform" column="platform"/><result property="brandName" column="brand_name"/><result property="deptName" column="dept_name"/><result property="ownerName" column="owner_name"/><result property="gmvTarget" column="gmv_target"/><result property="salesTarget" column="sales_target"/><result property="profitTarget" column="profit_target"/><result property="costTarget" column="cost_target"/><result property="adCostTarget" column="ad_cost_target"/><result property="roiTarget" column="roi_target"/><result property="profitRateTarget" column="profit_rate_target"/><result property="status" column="status"/><result property="remark" column="remark"/><result property="createBy" column="create_by"/><result property="createTime" column="create_time"/><result property="updateBy" column="update_by"/><result property="updateTime" column="update_time"/></resultMap>
    <sql id="cols">id,year,company_subject_id,profit_unit_id,company_name,subject_name,profit_unit_name,platform,brand_name,dept_name,owner_name,gmv_target,sales_target,profit_target,cost_target,ad_cost_target,roi_target,profit_rate_target,status,remark,create_by,create_time,update_by,update_time</sql>
    <select id="selectBizTargetYearById" resultMap="BaseResult">select <include refid="cols"/> from biz_target_year where id=#{id}</select>
    <select id="selectByYearAndProfitUnit" resultMap="BaseResult">select <include refid="cols"/> from biz_target_year where year=#{year} <choose><when test="profitUnitId!=null">and profit_unit_id=#{profitUnitId}</when><otherwise>and profit_unit_name=#{profitUnitName}</otherwise></choose> limit 1</select>
    <select id="selectBizTargetYearList" resultMap="BaseResult">select <include refid="cols"/> from biz_target_year <where><if test="year!=null">and year=#{year}</if><if test="profitUnitName!=null and profitUnitName!=''">and profit_unit_name like concat('%',#{profitUnitName},'%')</if><if test="platform!=null and platform!=''">and platform=#{platform}</if><if test="brandName!=null and brandName!=''">and brand_name=#{brandName}</if></where> order by year desc,id desc</select>
    <insert id="insertBizTargetYear" parameterType="com.ruoyi.dingtalk.domain.biz.BizTargetYear" useGeneratedKeys="true" keyProperty="id">insert into biz_target_year(year,company_subject_id,profit_unit_id,company_name,subject_name,profit_unit_name,platform,brand_name,dept_name,owner_name,gmv_target,sales_target,profit_target,cost_target,ad_cost_target,roi_target,profit_rate_target,status,remark,create_by,create_time) values(#{year},#{companySubjectId},#{profitUnitId},#{companyName},#{subjectName},#{profitUnitName},#{platform},#{brandName},#{deptName},#{ownerName},#{gmvTarget},#{salesTarget},#{profitTarget},#{costTarget},#{adCostTarget},#{roiTarget},#{profitRateTarget},#{status},#{remark},#{createBy},now())</insert>
    <update id="updateBizTargetYear" parameterType="com.ruoyi.dingtalk.domain.biz.BizTargetYear">update biz_target_year <set>year=#{year},company_subject_id=#{companySubjectId},profit_unit_id=#{profitUnitId},company_name=#{companyName},subject_name=#{subjectName},profit_unit_name=#{profitUnitName},platform=#{platform},brand_name=#{brandName},dept_name=#{deptName},owner_name=#{ownerName},gmv_target=#{gmvTarget},sales_target=#{salesTarget},profit_target=#{profitTarget},cost_target=#{costTarget},ad_cost_target=#{adCostTarget},roi_target=#{roiTarget},profit_rate_target=#{profitRateTarget},status=#{status},remark=#{remark},update_by=#{updateBy},update_time=now()</set> where id=#{id}</update>
    <delete id="deleteBizTargetYearByIds">delete from biz_target_year where id in <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
