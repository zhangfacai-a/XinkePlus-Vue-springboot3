<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.dingtalk.mapper.BizBudgetMonthMapper">
    <resultMap id="BaseResult" type="com.ruoyi.dingtalk.domain.biz.BizBudgetMonth"><id property="id" column="id"/><result property="year" column="year"/><result property="month" column="month"/><result property="companySubjectId" column="company_subject_id"/><result property="profitUnitId" column="profit_unit_id"/><result property="companyName" column="company_name"/><result property="subjectName" column="subject_name"/><result property="profitUnitName" column="profit_unit_name"/><result property="platform" column="platform"/><result property="brandName" column="brand_name"/><result property="deptName" column="dept_name"/><result property="ownerName" column="owner_name"/><result property="gmvBudget" column="gmv_budget"/><result property="salesBudget" column="sales_budget"/><result property="profitBudget" column="profit_budget"/><result property="costBudget" column="cost_budget"/><result property="adCostBudget" column="ad_cost_budget"/><result property="roiBudget" column="roi_budget"/><result property="profitRateBudget" column="profit_rate_budget"/><result property="status" column="status"/><result property="remark" column="remark"/><result property="createBy" column="create_by"/><result property="createTime" column="create_time"/><result property="updateBy" column="update_by"/><result property="updateTime" column="update_time"/></resultMap>
    <sql id="cols">id,year,month,company_subject_id,profit_unit_id,company_name,subject_name,profit_unit_name,platform,brand_name,dept_name,owner_name,gmv_budget,sales_budget,profit_budget,cost_budget,ad_cost_budget,roi_budget,profit_rate_budget,status,remark,create_by,create_time,update_by,update_time</sql>
    <select id="selectBizBudgetMonthById" resultMap="BaseResult">select <include refid="cols"/> from biz_budget_month where id=#{id}</select>
    <select id="selectByYearMonthAndProfitUnit" resultMap="BaseResult">select <include refid="cols"/> from biz_budget_month where year=#{year} and month=#{month} <choose><when test="profitUnitId!=null">and profit_unit_id=#{profitUnitId}</when><otherwise>and profit_unit_name=#{profitUnitName}</otherwise></choose> limit 1</select>
    <select id="selectBizBudgetMonthList" resultMap="BaseResult">select <include refid="cols"/> from biz_budget_month <where><if test="year!=null">and year=#{year}</if><if test="month!=null">and month=#{month}</if><if test="profitUnitName!=null and profitUnitName!=''">and profit_unit_name like concat('%',#{profitUnitName},'%')</if><if test="platform!=null and platform!=''">and platform=#{platform}</if><if test="brandName!=null and brandName!=''">and brand_name=#{brandName}</if></where> order by year desc,month desc,id desc</select>
    <insert id="insertBizBudgetMonth" parameterType="com.ruoyi.dingtalk.domain.biz.BizBudgetMonth" useGeneratedKeys="true" keyProperty="id">insert into biz_budget_month(year,month,company_subject_id,profit_unit_id,company_name,subject_name,profit_unit_name,platform,brand_name,dept_name,owner_name,gmv_budget,sales_budget,profit_budget,cost_budget,ad_cost_budget,roi_budget,profit_rate_budget,status,remark,create_by,create_time) values(#{year},#{month},#{companySubjectId},#{profitUnitId},#{companyName},#{subjectName},#{profitUnitName},#{platform},#{brandName},#{deptName},#{ownerName},#{gmvBudget},#{salesBudget},#{profitBudget},#{costBudget},#{adCostBudget},#{roiBudget},#{profitRateBudget},#{status},#{remark},#{createBy},now())</insert>
    <update id="updateBizBudgetMonth" parameterType="com.ruoyi.dingtalk.domain.biz.BizBudgetMonth">update biz_budget_month <set>year=#{year},month=#{month},company_subject_id=#{companySubjectId},profit_unit_id=#{profitUnitId},company_name=#{companyName},subject_name=#{subjectName},profit_unit_name=#{profitUnitName},platform=#{platform},brand_name=#{brandName},dept_name=#{deptName},owner_name=#{ownerName},gmv_budget=#{gmvBudget},sales_budget=#{salesBudget},profit_budget=#{profitBudget},cost_budget=#{costBudget},ad_cost_budget=#{adCostBudget},roi_budget=#{roiBudget},profit_rate_budget=#{profitRateBudget},status=#{status},remark=#{remark},update_by=#{updateBy},update_time=now()</set> where id=#{id}</update>
    <delete id="deleteBizBudgetMonthByIds">delete from biz_budget_month where id in <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
