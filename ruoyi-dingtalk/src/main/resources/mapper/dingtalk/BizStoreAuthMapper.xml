<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.dingtalk.mapper.BizStoreAuthMapper">
    <resultMap id="BaseResult" type="com.ruoyi.dingtalk.domain.biz.BizStoreAuth"><id property="id" column="id"/><result property="companySubjectId" column="company_subject_id"/><result property="profitUnitId" column="profit_unit_id"/><result property="platform" column="platform"/><result property="storeCode" column="store_code"/><result property="storeName" column="store_name"/><result property="authAccount" column="auth_account"/><result property="authSubject" column="auth_subject"/><result property="authStatus" column="auth_status"/><result property="openTime" column="open_time"/><result property="expireTime" column="expire_time"/><result property="status" column="status"/><result property="remark" column="remark"/><result property="createBy" column="create_by"/><result property="createTime" column="create_time"/><result property="updateBy" column="update_by"/><result property="updateTime" column="update_time"/></resultMap>
    <sql id="cols">id,company_subject_id,profit_unit_id,platform,store_code,store_name,auth_account,auth_subject,auth_status,open_time,expire_time,status,remark,create_by,create_time,update_by,update_time</sql>
    <select id="selectBizStoreAuthById" resultMap="BaseResult">select <include refid="cols"/> from biz_store_auth where id=#{id}</select>
    <select id="selectByPlatformAndStore" resultMap="BaseResult">select <include refid="cols"/> from biz_store_auth where store_name=#{storeName}<if test="platform!=null and platform!=''"> and platform=#{platform}</if><if test="storeCode!=null and storeCode!=''"> and store_code=#{storeCode}</if> limit 1</select>
    <select id="selectBizStoreAuthList" resultMap="BaseResult">select <include refid="cols"/> from biz_store_auth <where><if test="profitUnitId!=null">and profit_unit_id=#{profitUnitId}</if><if test="platform!=null and platform!=''">and platform=#{platform}</if><if test="storeName!=null and storeName!=''">and store_name like concat('%',#{storeName},'%')</if><if test="authStatus!=null and authStatus!=''">and auth_status=#{authStatus}</if><if test="status!=null and status!=''">and status=#{status}</if></where> order by id desc</select>
    <insert id="insertBizStoreAuth" parameterType="com.ruoyi.dingtalk.domain.biz.BizStoreAuth" useGeneratedKeys="true" keyProperty="id">insert into biz_store_auth(company_subject_id,profit_unit_id,platform,store_code,store_name,auth_account,auth_subject,auth_status,open_time,expire_time,status,remark,create_by,create_time) values(#{companySubjectId},#{profitUnitId},#{platform},#{storeCode},#{storeName},#{authAccount},#{authSubject},#{authStatus},#{openTime},#{expireTime},#{status},#{remark},#{createBy},now())</insert>
    <update id="updateBizStoreAuth" parameterType="com.ruoyi.dingtalk.domain.biz.BizStoreAuth">update biz_store_auth <set>company_subject_id=#{companySubjectId},profit_unit_id=#{profitUnitId},platform=#{platform},store_code=#{storeCode},store_name=#{storeName},auth_account=#{authAccount},auth_subject=#{authSubject},auth_status=#{authStatus},open_time=#{openTime},expire_time=#{expireTime},status=#{status},remark=#{remark},update_by=#{updateBy},update_time=now()</set> where id=#{id}</update>
    <delete id="deleteBizStoreAuthByIds">delete from biz_store_auth where id in <foreach collection="ids" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
