<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.ruoyi.dingtalk.mapper.BizImportErrorLogMapper">
    <resultMap id="BaseResult" type="com.ruoyi.dingtalk.domain.imports.BizImportErrorLog"><id property="id" column="id"/><result property="batchId" column="batch_id"/><result property="sheetName" column="sheet_name"/><result property="rowNo" column="row_no"/><result property="columnName" column="column_name"/><result property="fieldName" column="field_name"/><result property="rawValue" column="raw_value"/><result property="errorType" column="error_type"/><result property="errorMsg" column="error_msg"/><result property="createTime" column="create_time"/></resultMap>
    <select id="selectByBatchId" resultMap="BaseResult">select * from biz_import_error_log where batch_id=#{batchId} order by row_no asc,id asc</select>
    <insert id="insertError" parameterType="com.ruoyi.dingtalk.domain.imports.BizImportErrorLog" useGeneratedKeys="true" keyProperty="id">insert into biz_import_error_log(batch_id,sheet_name,row_no,column_name,field_name,raw_value,error_type,error_msg,create_time) values(#{batchId},#{sheetName},#{rowNo},#{columnName},#{fieldName},#{rawValue},#{errorType},#{errorMsg},now())</insert>
    <insert id="batchInsert"><foreach collection="list" item="e" separator=";">insert into biz_import_error_log(batch_id,sheet_name,row_no,column_name,field_name,raw_value,error_type,error_msg,create_time) values(#{e.batchId},#{e.sheetName},#{e.rowNo},#{e.columnName},#{e.fieldName},#{e.rawValue},#{e.errorType},#{e.errorMsg},now())</foreach></insert>
    <delete id="deleteByBatchIds">delete from biz_import_error_log where batch_id in <foreach collection="batchIds" item="id" open="(" separator="," close=")">#{id}</foreach></delete>
</mapper>
